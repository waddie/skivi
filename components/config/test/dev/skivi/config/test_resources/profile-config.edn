{:database {:connection-string #profile
                                {:dev  "postgresql://localhost:5432/dev_db"
                                 :prod "postgresql://localhost:5432/prod_db"
                                 :test "postgresql://localhost:5432/test_db"}
            :password          "postgres"
            :pool-config       {:connection-timeout 30000
                                :idle-timeout       600000
                                :max-lifetime       1800000
                                :maximum-pool-size  #profile {:dev  5
                                                              :prod 20
                                                              :test 3}
                                :minimum-idle       2}
            :username          "postgres"}
 :logging  #profile {:dev  {:format      :pretty
                            :include-mdc true
                            :level       :debug}
                     :prod {:format      :json
                            :include-mdc true
                            :level       :info}
                     :test {:format      :json
                            :include-mdc false
                            :level       :warn}}
 :queue    {:batch-complete-delay 50
            :batch-fail-delay     50
            :local-queue          {:enabled true
                                   :refetch-threshold 10
                                   :size    50
                                   :ttl     60000}}
 :schema   {:job-schemas {}
            :name        "job_system"
            :validate-payloads true}
 :worker   {:concurrency            4
            :file-extensions        [".clj" ".cljc"]
            :graceful-shutdown-timeout 30000
            :max-job-execution-time 300000
            :poll-interval          2000
            :task-directory         "tasks"}}