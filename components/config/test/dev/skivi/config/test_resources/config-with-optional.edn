{:cleanup    {:enabled  false
              :retention-periods {:task-identifiers "14 days"}
              :schedule "0 2 * * *"
              :tasks    [:gc-task-identifiers]}
 :cron       {:default-backfill-period 7200000
              :enabled  true
              :file     "custom-crontab.edn"
              :timezone "America/New_York"}
 :database   {:connection-string "postgresql://localhost:5432/test_db"
              :pool-config       {:connection-timeout 30000
                                  :idle-timeout       600000
                                  :max-lifetime       1800000
                                  :maximum-pool-size  10
                                  :minimum-idle       2}}
 :logging    {:format      :pretty
              :include-mdc false
              :level       :debug}
 :monitoring {:events       {:buffer-size 2000
                             :enabled     false}
              :health-check {:enabled true
                             :port    4000}
              :metrics      {:enabled  true
                             :registry nil}}
 :queue      {:batch-complete-delay 50
              :batch-fail-delay     50
              :local-queue          {:enabled true
                                     :refetch-threshold 10
                                     :size    50
                                     :ttl     60000}}
 :retry      {:base-delay   500
              :jitter       0.2
              :max-attempts 10
              :max-delay    1800000
              :multiplier   1.5
              :strategy     :linear}
 :schema     {:job-schemas {}
              :name        "job_system"
              :validate-payloads true}
 :worker     {:concurrency            4
              :file-extensions        [".clj" ".cljc"]
              :graceful-shutdown-timeout 30000
              :max-job-execution-time 300000
              :poll-interval          2000
              :task-directory         "tasks"}}